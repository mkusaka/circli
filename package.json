{
  "name": "circli",
  "version": "0.0.136",
  "description": "cli which implements useful command for circleci",
  "license": "MIT",
  "author": "mkusaka <hinoshita1992@gmail.com>",
  "repository": "https://github.com/mkusaka/circli.git",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "bump:patch": "npm version patch",
    "update": "curl -o swagger.json https://circleci.com/api/v2/openapi.json && pnpm run sortswagger",
    "sortswagger": "sort-json swagger.json && pnpm oxfmt --write swagger.json",
    "build": "tsc",
    "start": "node --import tsx src/index.ts",
    "test": "vitest",
    "generate-types": "openapi-typescript swagger.json -o src/types/circleci.ts",
    "lint": "oxlint -c oxlint.json $(find src test -name '*.ts')",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@cliffy/command": "npm:@jsr/cliffy__command@1.0.0-rc.8",
    "neverthrow": "^8.2.0",
    "openapi-fetch": "^0.17.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@tsconfig/node24": "24.0.4",
    "@types/node": "25.3.5",
    "msw": "2.12.10",
    "openapi-typescript": "7.13.0",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "sort-json": "2.0.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "packageManager": "pnpm@10.32.1"
}
